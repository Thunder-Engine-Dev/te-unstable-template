[node name="RowLoadFirst" parent="Presets" instance=ExtResource("15_mxo6u")]
layout_mode = 2
tweak_name = "load_save_from_world_start"
tweak_title_text = "save pipe: always first level of the world"
tweak_description_text = "Copies the behavior over from the original game, where save pipes ignore the level you were on.

Notice: enabling this tweak will not reset your save pipe until you enter it.

Notice 2: enabling this tweak will disable the level selector after beating the game. The world selector is unaffected."

[node name="RowF3" parent="Presets" instance=ExtResource("15_mxo6u")]
layout_mode = 2
tweak_name = "f3_keybind"
tweak_title_text = "f3 keybind to save game room"
tweak_description_text = "enables a quick shortcut to save room using the f3 key.

notice: if you are in options and have not selected \"exit\" (or the escape key) to go back, pressing f3 will not save the options you've changed! it will also not reset the scene if you're already in the save room."

[node name="RowF4" parent="Presets" instance=ExtResource("15_mxo6u")]
layout_mode = 2
tweak_name = "f4_keybind"
tweak_title_text = "f4 keybind to main menu"
tweak_description_text = "enables a quick shortcut to main menu using the f4 key.

notice: you cannot reset the scene if you are already in the main menu."

[node name="RowRevShop" parent="Presets" instance=ExtResource("15_mxo6u")]
layout_mode = 2
tweak_name = "revamp_item_shop"
tweak_title_text = "require pressing up in item shop"
tweak_description_text = "if disabled, touching a power-up in the item shop will immediately buy an item in the save room.

if enabled, it also requires the player to press the moving up key to buy an item."

[node name="RowFasterDel" parent="Presets" instance=ExtResource("15_mxo6u")]
layout_mode = 2
tweak_name = "faster_save_deletion"
tweak_title_text = "save pipe: faster save deletion"
tweak_description_text = "if disabled, deleting saves in the save game room takes 3 seconds (or 2.5s in 1.2x game speed).

if enabled, the time is reduced to 0.6 seconds (0.5s in 1.2x game speed)."

[node name="RowConsole" parent="Presets" instance=ExtResource("15_mxo6u")]
layout_mode = 2
tweak_name = "console_enabled"
tweak_title_text = "enable cheat commands (f1 key)"
tweak_description_text = "gives an ability to toggle debug console with the f1 key on keyboard.

please note: console commands are not supported and may result in crash in certain conditions.

warning: enabling this tweak will disable achievement progression and profile saving!
to restore achievements if still disabled, please, restart the game.
to enable saving with the console, use \"cv_forcesave\" and \"cv_forcesave_suspended\" commands. note that using these commands will mark your saves as \"cheated\" until you reset them."

