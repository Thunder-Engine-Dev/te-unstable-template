[node name="RowCircleFade" parent="Aesthetic" instance=ExtResource("15_mxo6u")]
layout_mode = 2
tweak_name = "replace_circle_transitions_with_fades"
tweak_title_text = "replace circle transitions with crossfades"
tweak_description_text = "If enabled, crossfades will replace nearly all circle transitions between scenes, pausing the game in the process.
Such transitions take slightly less time than the default circle ones.

This behavior is similar to versions 5.0+ of the original game."

[node name="RowSmoothCam" parent="Aesthetic" instance=ExtResource("15_mxo6u")]
layout_mode = 2
tweak_name = "enable_smooth_cam_transitions"
default_value = true
tweak_title_text = "smooth camera transitions between areas"
tweak_description_text = "smoothes out camera movement between certain areas, such as the save game room."

[node name="RowBlur" parent="Aesthetic" instance=ExtResource("15_mxo6u")]
layout_mode = 2
tweak_name = "enable_blur_transitions"
default_value = true
tweak_title_text = "blur transitions between pipe warp areas"
tweak_description_text = "adds a blur transition each time the player warps into a new area mid-level. disable this tweak to make the new area load immediately."

[node name="RowPauseSuit" parent="Aesthetic" instance=ExtResource("15_mxo6u")]
layout_mode = 2
tweak_name = "pause_on_suit_change"
tweak_title_text = "pause on player suit change"
tweak_description_text = "each time the player receives a powerup or takes damage, the entire game pauses for a second, giving the user more time to react."

[node name="RowSkid" parent="Aesthetic" instance=ExtResource("15_mxo6u")]
layout_mode = 2
tweak_name = "player_skid_animation"
tweak_title_text = "player skidding effects"
tweak_description_text = "enables the skidding animation and particles, similar to something you would see in other mario games.

note: this tweak does not affect gameplay in any way!"

