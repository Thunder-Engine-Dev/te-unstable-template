[node name="RowProgress" parent="Gameplay" instance=ExtResource("15_mxo6u")]
layout_mode = 2
tweak_name = "progress_continue"
default_value = true
tweak_title_text = "save suspended game on exit
(aka progress continue)"
tweak_description_text = "each time you complete a level, a one-time save is made with your entire progress, including your power state, lives, and the level you were on. You can access it at any time."

[node name="RowBowser" parent="Gameplay" instance=ExtResource("15_mxo6u")]
layout_mode = 2
tweak_name = "bowser_stomping"
tweak_title_text = "less bouncy bowser stomping"
tweak_description_text = "Mimics the behavior from the original game, where you receive a push forwards each time Bowser is stomped, and you cannot bounce as high.

Disabling this tweak makes stomping on Bowser identical to other enemies."

[node name="RowCrouch" parent="Gameplay" instance=ExtResource("15_mxo6u")]
layout_mode = 2
tweak_name = "crouch_jumping"
default_value = true
tweak_title_text = "crouch jumping"
tweak_description_text = "This tweak allows you to jump while crouching with Super or better form.

If you jump while crouching, you won't be able to accelerate beyond the walking speed limit, but you will maintain your previous speed. In this state, there is no passive deceleration when no buttons are pressed.

If disabled, bricks above your head will break automatically while crouching. If enabled, you will need to jump to break bricks or activate bonus blocks."

[node name="RowCoyote" parent="Gameplay" instance=ExtResource("15_mxo6u")]
layout_mode = 2
tweak_name = "coyote_time"
default_value = true
tweak_title_text = "coyote time (recommended)"
tweak_description_text = "running off of a ledge will grant a very brief period of additional time to make a jump."

[node name="RowSuperJumpBug" parent="Gameplay" instance=ExtResource("15_mxo6u")]
layout_mode = 2
tweak_name = "super_jump_bug"
tweak_title_text = "super jump bug (not recommended)"
tweak_description_text = "(From the original mario forever)
if grounded, stomping on enemies will not immediately make you bounce off.

notice: any unintended behavior of the game (crashes, etc.) derived from this bug simulation is not supported, use at your own risk.

this tweak is not available in expert mode."

[node name="RowCheckpoints" parent="Gameplay" instance=ExtResource("15_mxo6u")]
layout_mode = 2
tweak_name = "checkpoints"
default_value = true
tweak_title_text = "mid-level checkpoints"
tweak_description_text = "v4.4 added checkpoints to the whole game. Disabling this tweak makes the game more challenging."

[node name="RowStompCombo" parent="Gameplay" instance=ExtResource("15_mxo6u")]
layout_mode = 2
tweak_name = "stomping_combo"
tweak_title_text = "stomping combos"
tweak_description_text = "The stomping combos were not a thing in the original Mario Forever. A combo goes like this:

100 > 200 > 400 > 500 > 800 > 1000 > 2000 > 4000 > 5000 > 8000 > 1up > back to 100.

Notice: this tweak has no effect in Mario Minix and Expert Mode."

[node name="RowSpring" parent="Gameplay" instance=ExtResource("15_mxo6u")]
layout_mode = 2
tweak_name = "better_springboards"
tweak_title_text = "easier springboards (no timing required)"
tweak_description_text = "When disabled, springboards require the user to press the jump button up to 1/10 of a second in advance before touching the springboard to bounce higher.

Enabling this tweak makes you always jump at the maximum height as long as you hold the jump button, making springboards easier to control."

[node name="RowAutorun" parent="Gameplay" instance=ExtResource("15_mxo6u")]
layout_mode = 2
tweak_name = "autorun"
tweak_title_text = "autorun"
tweak_description_text = "When enabled, it inverts the behavior of the run button: holding it will make you walk instead, and vice versa."

[node name="RowRetroDmg" parent="Gameplay" instance=ExtResource("15_mxo6u")]
layout_mode = 2
tweak_name = "retro_damage_system"
tweak_title_text = "\"SMB1 DAMAGE SYSTEM\" challenge mode"
tweak_description_text = "Like in Super Mario Bros. 1, getting hit while powered up causes the player to shrink to the small form instead of going to the super form first.

This challenge is completely optional, and there is no reward for it."

